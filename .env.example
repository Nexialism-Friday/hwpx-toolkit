# hwpx-toolkit Environment Variables
# Copy this file to .env and fill in your values

# === Required ===

# Path to HWPX template directory (contains Contents/, META-INF/, etc.)
HWPX_TEMPLATE_DIR=/path/to/your/hwpx_template

# === Optional ===

# Default output directory for generated HWPX files
HWPX_OUTPUT_DIR=/tmp/hwpx_output

# Path to hwp5txt binary (auto-detected via PATH if not set)
# HWP5TXT_PATH=/usr/local/bin/hwp5txt

# Windows Python executable path (WSL only, for COM automation features)
# HWPX_WINDOWS_PYTHON=/mnt/c/Users/YourUsername/AppData/Local/Programs/Python/Python314/python.exe

# === Telegram integration (optional, for send_hwpx_telegram MCP tool) ===
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
